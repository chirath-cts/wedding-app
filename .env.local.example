# Copy this file to ".env.local" (same folder) and fill in your real values.
# .env.local is already excluded from git, so these secrets never get
# committed or pushed to GitHub.

# From Supabase dashboard: Project Settings -> API -> "Project URL"
NEXT_PUBLIC_SUPABASE_URL=

# From Supabase dashboard: Project Settings -> API -> "service_role" key
# (the SECRET one, not the "anon public" one)
SUPABASE_SERVICE_ROLE_KEY=

# The password you'll type in to log into /admin
ADMIN_PASSWORD=

# Your site's live URL, used to build shareable invite links.
# For local testing, leave this as-is. After deploying, set it to your
# real Vercel URL (e.g. https://your-wedding.vercel.app).
NEXT_PUBLIC_SITE_URL=http://localhost:3000
